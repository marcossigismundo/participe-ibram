{
    "name": "ibram/participe-ibram",
    "description": "Plataforma federal Participe Ibram - Cadastro de Agentes para Participação Social do Ibram (Portaria 3230/2024).",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "keywords": ["wordpress", "plugin", "ibram", "participe", "museus", "lgpd", "federal"],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=7.4",
        "ext-sodium": "*",
        "ext-mbstring": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0",
        "phpstan/phpstan": "^1.10",
        "phpstan/phpstan-strict-rules": "^1.5"
    },
    "autoload": {
        "psr-4": {
            "Ibram\\ParticipeIbram\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ibram\\ParticipeIbram\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true
    },
    "scripts": {
        "lint": "phpcs --standard=WordPress src/ tests/",
        "lint:fix": "phpcbf --standard=WordPress src/ tests/",
        "test": "phpunit",
        "phpstan": "phpstan analyse --level=6 src/"
    }
}
